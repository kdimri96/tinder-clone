# ─────────────────────────────────────────────────────────────────
# PRODUCTION ENVIRONMENT VARIABLES
# Copy this to .env and fill in real values before deploying.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000

# MongoDB Atlas connection string
# Get from: https://cloud.mongodb.com → Clusters → Connect
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/tinder-clone?retryWrites=true&w=majority

# JWT Secrets — generate with: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated list of allowed frontend origins
# Example: https://myapp.com,https://www.myapp.com
ALLOWED_ORIGINS=https://yourdomain.com

# Google OAuth Web Client ID
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID.apps.googleusercontent.com

# Razorpay
RAZORPAY_KEY_ID=rzp_live_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET

# File uploads directory (for local disk; replace with S3/Cloudinary for production)
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
